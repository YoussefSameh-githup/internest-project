# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git.

# --- Django core ---
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=youssefsameh.pythonanywhere.com,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://youssefsameh.pythonanywhere.com

# --- HTTPS hardening (set to False on a server without TLS) ---
DJANGO_SECURE_SSL_REDIRECT=True

# --- Email (SendGrid SMTP) ---
# Use console backend during development to avoid sending real emails:
#   DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.sendgrid.net
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_HOST_USER=apikey
DJANGO_EMAIL_HOST_PASSWORD=replace-with-your-sendgrid-api-key
DJANGO_DEFAULT_FROM_EMAIL=internest.opportunities@gmail.com
