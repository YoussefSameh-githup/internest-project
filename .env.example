# Copy this file to `.env` at the project root, then fill in real values.
# `.env` is in .gitignore — never commit it.
#
# Both the WSGI app and `python manage.py shell` read from this file via
# django-environ. The web app no longer needs os.environ['...'] lines in
# the PythonAnywhere WSGI file for these variables.

# --- Django core ---
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=youssefsameh.pythonanywhere.com,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://youssefsameh.pythonanywhere.com
DJANGO_SECURE_SSL_REDIRECT=False

# --- Email (SendGrid HTTPS API via Anymail) ---
DJANGO_EMAIL_BACKEND=anymail.backends.sendgrid.EmailBackend
ANYMAIL_SENDGRID_API_KEY=SG.replace-with-your-sendgrid-api-key
DJANGO_DEFAULT_FROM_EMAIL=internest.opportunities@gmail.com
